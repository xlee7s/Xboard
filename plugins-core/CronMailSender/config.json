{
    "name": "定时邮件发送",
    "code": "cron_mail_sender",
    "version": "2.0.0",
    "description": "分批发送邮件，每N天执行一次，每2秒一封，支持断点续跑",
    "author": "HuaXianRen",
    "require": {
        "xboard": ">=1.0.0"
    },
    "config": {
        "interval_days": {
            "type": "number",
            "default": 1,
            "label": "发送间隔（天）",
            "description": "必须大于等于1，违规值强制以1天执行"
        },
        "batch_size": {
            "type": "number",
            "default": 500,
            "label": "单批处理数量",
            "description": "每次执行最多处理多少用户"
        },
        "enable_log": {
            "type": "boolean",
            "default": true,
            "label": "开启日志",
            "description": "是否记录发送日志"
        },
        "email_subject": {
            "type": "string",
            "default": "系统通知",
            "label": "邮件标题",
            "description": "邮件标题内容"
        },
        "email_content": {
            "type": "text",
            "default": "这是一封系统自动发送的邮件",
            "label": "邮件内容",
            "description": "邮件正文内容"
        },
        "status": {
            "type": "boolean",
            "default": false,
            "label": "是否开启任务",
            "description": "是否开启自动发送邮件任务"
        }
    }
}